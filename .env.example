# CarWash Pro Environment Variables
# Copy this to .env and fill in your real values
# Add .env to .gitignore before committing!

MONGO_URI=mongodb://127.0.0.1:27017/carwashpro
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/carwashpro?retryWrites=true&w=majority

EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_app_password
# Generate Gmail App Password: https://myaccount.google.com/apppasswords

PORT=3000
DEV_RESET_CODE=694953

# For production deployment (Render, etc.)
NODE_ENV=production
